# Build artifacts — regenerated by CMake, never source-controlled.
build/

# Project-local MySQL instance state — data, socket, logs, pid.
# This is machine-specific runtime state, not source. Keeping it out of git is
# also why deleting the folder fully removes the database from your system.
db/data/
db/*.sock
db/*.sock.lock
db/*.pid
db/*.err

# macOS noise
.DS_Store

# Personal study notes — kept locally, not published.
learning/
